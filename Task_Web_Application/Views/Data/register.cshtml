@using Task_Web_Application.Models
@model RegisterModel
@{
    ViewData["Title"] = "register";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Register</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            background: radial-gradient(circle at top left, rgba(124,58,237,.18), transparent 35%), radial-gradient(circle at bottom right, rgba(59,130,246,.18), transparent 35%), linear-gradient(135deg, #f8fafc, #eef2ff);
            font-family: 'Inter', sans-serif;
            color: #2c2c2c;
        }

        .card-wrapper {
            display: flex;
            justify-content: center;
            padding: 48px 24px;
        }

        .card {
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            width: 100%;
            max-width: 520px;
            padding: 48px 44px;
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.4);
            box-shadow: 0 20px 50px rgba(0,0,0,.08), 0 0 0 1px rgba(255,255,255,.4);
        }

        .card-header h1 {
            font-family: 'Inter', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            color: #111827;
        }

            .card-header h1 {
                font-family: 'DM Serif Display', serif;
                font-size: 1.9rem;
                font-weight: 400;
                color: #1a1a1a;
                margin-bottom: 6px;
            }

            .card-header p {
                font-size: 0.85rem;
                color: #9a9a9a;
            }

        .field {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-size: 0.78rem;
            font-weight: 500;
            color: #6b6b6b;
            margin-bottom: 7px;
            letter-spacing: 0.01em;
        }

        input, select {
            width: 100%;
            background: #f7f5f2;
            border: 1px solid transparent;
            border-radius: 8px;
            padding: 11px 14px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.88rem;
            font-weight: 300;
            color: #2c2c2c;
            outline: none;
            transition: border-color 0.2s, background 0.2s;
            appearance: none;
            -webkit-appearance: none;
        }

            input::placeholder {
                color: #c4c0bb;
            }

            input:focus, select:focus {
                background: #ffffff;
                border-color: #c8b89a;
            }

        .select-wrap {
            position: relative;
        }

            .select-wrap::after {
                content: '↓';
                position: absolute;
                right: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #b0aba4;
                font-size: 0.78rem;
                pointer-events: none;
            }

        .row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .check-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 28px;
        }

        input[type="checkbox"] {
            width: 16px;
            height: 16px;
            border-radius: 4px;
            border: 1.5px solid #d4cfc9;
            background: #f7f5f2;
            cursor: pointer;
            padding: 0;
            flex-shrink: 0;
            accent-color: #8a7560;
        }

        .check-row label {
            margin: 0;
            font-size: 0.78rem;
            color: #9a9a9a;
            font-weight: 300;
        }

        .check-row a {
            color: #8a7560;
            text-decoration: none;
        }

            .check-row a:hover {
                text-decoration: underline;
            }

        .btn {
            width: 100%;
            border: none;
            border-radius: 10px;
            padding: 14px;
            cursor: pointer;
            background: linear-gradient( 135deg, #4f46e5, #7c3aed );
            color: white;
            font-size: .95rem;
            font-weight: 600;
            transition: .3s;
        }

            .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(79,70,229,.35);
            }


        .footer-text {
            text-align: center;
            margin-top: 20px;
            font-size: 0.8rem;
            color: #b0aba4;
        }

            .footer-text a {
                color: #8a7560;
                text-decoration: none;
            }

                .footer-text a:hover {
                    text-decoration: underline;
                }

        .divider {
            height: 1px;
            background: #eeebe7;
            margin: 28px 0;
        }

        .blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            z-index: -1;
        }

        .blob-1 {
            width: 300px;
            height: 300px;
            background: #8b5cf6;
            top: -100px;
            left: -100px;
            opacity: .25;
        }

        .blob-2 {
            width: 350px;
            height: 350px;
            background: #3b82f6;
            bottom: -120px;
            right: -120px;
            opacity: .25;
        }

        .badge-title {
            color: #4f46e5;
            font-size: .75rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .logo-circle {
            width: 70px;
            height: 70px;
            margin: auto;
            margin-bottom: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 50%;
            background: linear-gradient( 135deg, #4f46e5, #7c3aed );
            color: white;
            font-size: 28px;
        }

        input:focus,
        select:focus {
            background: white;
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79,70,229,.15);
        }

        .mini-stats {
            display: flex;
            justify-content: space-between;
            margin-top: 25px;
            text-align: center;
        }

            .mini-stats strong {
                display: block;
                font-size: 1rem;
            }

            .mini-stats span {
                font-size: .75rem;
                color: #888;
            }
    </style>
</head>
<body>
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>

    <div class="card-wrapper">
        <div class="card">

            <div class="card-header text-center">

                <p class="badge-title">
                    TASK MANAGEMENT PLATFORM
                </p>

                <div class="logo-circle">
                    📋
                </div>

                <h1>Create Account</h1>

                <p>
                    Start organizing your work smarter
                </p>

            </div>

            <form method="post">


                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">

                        <div class="field">
                            <label>Username</label>

                            <input type="text"
                                   placeholder="e.g. johndoe"
                                   asp-for="Username">

                            <span asp-validation-for="Username"
                                  class="text-danger"></span>
                        </div>

                        <div class="field">
                            <label>Date of Birth</label>

                            <input type="date"
                                   asp-for="Dob">

                            <span asp-validation-for="Dob"
                                  class="text-danger"></span>
                        </div>

                    </div>

                    <div class="field">
                        <label>Email Address</label>

                        <input type="email"
                               placeholder="you@example.com"
                               asp-for="Email">

                        <span asp-validation-for="Email"
                              class="text-danger"></span>
                    </div>

                    <div class="field">
                        <label>Password</label>

                        <input type="password"
                               placeholder="Create a password"
                               asp-for="Password">

                        <span asp-validation-for="Password"
                              class="text-danger"></span>
                    </div>

                    <div class="field">
                        <label>Account Type</label>

                        <div class="select-wrap">

                            <select asp-for="Type">

                                <option value="">Select role</option>

                                <option value="user">User (Create tasks)</option>

                                <option value="worker">Worker (Solve tasks)</option>

                                <option value="admin">Admin (Manage system)</option>

                            </select>

                        </div>

                        <span asp-validation-for="Type"
                              class="text-danger"></span>
                    </div>

                    <div class="divider"></div>

                    <div class="form-check mb-3">

                        <input asp-for="AcceptTerms"
                               class="form-check-input" />

                        <label asp-for="AcceptTerms"
                               class="form-check-label">
                            I agree to the Terms & Conditions
                        </label>

                    </div>

                    <span asp-validation-for="AcceptTerms"
                          class="text-danger"></span>

                    <input type="submit"
                           class="btn"
                           value="Sign Up">
                   


            </form>
            <div class="mini-stats">

                <div>
                    <strong>5000+</strong>
                    <span>Tasks</span>
                </div>

                <div>
                    <strong>250+</strong>
                    <span>Teams</span>
                </div>

                <div>
                    <strong>99%</strong>
                    <span>Uptime</span>
                </div>

            </div>

            <p class="footer-text">
                Already have an account? <a asp-controller="data" asp-action="Login">Log in</a>
            </p>

        </div>
    </div>

</body>
</html>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}   