@model IEnumerable<Task_Web_Application.Models.TaskItem>

@{
    ViewData["Title"] = "Completed Tasks";
    Layout = "~/Views/Shared/_AdminHomepage.cshtml";
}

<div class="table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Description</th>
                <th>Created By</th>
                <th>Assigned To</th>
                <th>Created Date</th>
                <th>Status</th>
                <th>Approve</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Title</td>
                        <td>@item.Description</td>
                        <td>@item.CreatedBy</td>
                        <td>@item.AssignedTo</td>
                        <td>@item.CreatedDate.ToString("dd MMM yyyy")</td>

                        <td>
                            <span class="badge bg-success">
                                @item.Status
                            </span>
                        </td>

                        <!-- APPROVE -->
                        <td>
                            <form asp-action="ApproveTask"
                                  asp-controller="Data"
                                  method="post"
                                  style="display:inline;">

                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />

                                <button type="submit"
                                        class="btn btn-sm btn-success">
                                    Approve
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">
                        No completed tasks yet.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>