@{
    ViewData["Title"] = "Worker Dashboard";
    Layout = "~/Views/Shared/_UserHomepage.cshtml";
}

<div class="container mt-4">

    <h2 class="mb-4">Worker Dashboard</h2>

    <div class="row">

        <div class="col-md-6 mb-3">
            <div class="card shadow-sm">
                <div class="card-body">

                    <h5>Available Tasks</h5>
                    <p>View all available tasks and take one.</p>

                    <a asp-controller="Task"
                       asp-action="Index"
                       class="btn btn-primary">
                        Open
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card shadow-sm">
                <div class="card-body">

                    <h5>My Tasks</h5>
                    <p>View tasks assigned to you.</p>

                    <a asp-controller="Task"
                       asp-action="MyTasks"
                       class="btn btn-success">
                        Open
                    </a>

                </div>
            </div>
        </div>

    </div>

</div>